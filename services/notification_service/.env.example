RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/%2F
NOTIFICATION_EMAIL_QUEUE=notification.email.queue
NOTIFICATION_MAX_RETRIES=5
# Future channels (push/sms) can reuse same queue with channel field.

EMAIL_HOST=mail.adnproservice.com
EMAIL_PORT=465
EMAIL_HOST_USER=no-reply@adnproservice.com
EMAIL_HOST_PASSWORD=change-me
EMAIL_USE_SSL=True
EMAIL_TIMEOUT=20
DEFAULT_FROM_EMAIL=no-reply@adnproservice.com

# API de test SMTP pour Postman (désactivée par défaut en prod)
ENABLE_MAIL_TEST_API=false
MAIL_TEST_API_HOST=0.0.0.0
MAIL_TEST_API_PORT=8090
# Si défini, header obligatoire: Authorization: Bearer <token>
MAIL_TEST_API_TOKEN=
